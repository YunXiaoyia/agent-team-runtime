# Required for Next.js and some packages that expect flat node_modules
shamefully-hoist=true

# Reduce peer dependency noise during development
# Review these settings before production deployment
strict-peer-dependencies=false
auto-install-peers=true

# Local CUDA 11 environments make onnxruntime-node's postinstall fail unless the
# CUDA binary install is skipped and handled manually.
onnxruntime-node-install-cuda=skip
