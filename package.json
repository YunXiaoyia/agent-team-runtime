{
  "name": "agent-team-runtime",
  "version": "0.1.0",
  "private": true,
  "description": "Backend core runtime for multi-agent team collaboration.",
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter @agent-team-runtime/api dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -b",
    "prisma:generate": "PRISMA_GENERATE_SKIP_AUTOINSTALL=1 pnpm --filter @agent-team-runtime/api exec prisma generate --schema prisma/schema.prisma",
    "prisma:push": "prisma db push --schema apps/api/prisma/schema.prisma --skip-generate",
    "prisma:migrate": "prisma migrate dev --schema apps/api/prisma/schema.prisma"
  },
  "devDependencies": {
    "@types/node": "^22.15.29",
    "prisma": "^6.8.2",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.4"
  },
  "dependencies": {
    "@prisma/client": "^6.8.2",
    "@fastify/cors": "^11.0.1",
    "dotenv": "^16.5.0",
    "fastify": "^5.3.3",
    "socket.io": "^4.8.1",
    "zod": "^3.25.28"
  },
  "packageManager": "pnpm@11.1.3"
}
