generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Agent {
  id           String   @id
  name         String
  provider     String
  capabilities String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Thread {
  id        String   @id
  title     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  messages  Message[]
}

model Message {
  id        String   @id
  threadId  String
  sender    String
  role      String
  content   String
  metadata  String?
  createdAt DateTime @default(now())
  thread    Thread   @relation(fields: [threadId], references: [id], onDelete: Cascade)
}

model Invocation {
  id        String   @id
  threadId  String
  agentId   String
  status    String
  depth     Int      @default(0)
  input     String
  output    String?
  error     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
